# Supabase — get these from your project's API settings (Project Settings -> API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Discord invite shown in the "Join the Discord" CTA
VITE_DISCORD_URL=https://discord.gg/your-invite

# Admin "God Mode" secret. The /admin route asks for this token and compares it
# against this value. Keep it private — anyone with it gets full moderation power.
VITE_ADMIN_TOKEN=change-me-to-a-long-random-string
