# Supabase — get these from your project's API settings (Project Settings -> API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Discord invite shown in the "Join the Discord" CTA
VITE_DISCORD_URL=https://discord.gg/your-invite

# Admin "God Mode" token. This only PREFILLS the /admin login box — the real
# check is server-side: the token is validated against the `admin_secrets`
# table via the admin_check RPC, so the secret is never trusted from (or shipped
# in) the client bundle. Set the SAME value in admin_secrets (see migration
# 0002_admin.sql) and you can log in. Leave this blank in production if you'd
# rather type the token by hand.
VITE_ADMIN_TOKEN=
